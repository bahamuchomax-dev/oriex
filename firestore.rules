rules_version = '2';

/* ============================================================
 * Oriex Firestore Security Rules — pre-production hardened (through stage 4.6)
 * ------------------------------------------------------------
 * Roles come from SERVER-SET custom claims (request.auth.token.*),
 * NOT from client-writable fields. Only an admin (Admin SDK / a
 * Cloud Function gated by admin) sets `teacher` / `admin` claims, so
 * a student can never grant themselves teacher rights from the client.
 *
 * Hardening in this stage:
 *   - profiles: self writes are WHITELISTED (hasOnly), so a student
 *     cannot invent fields like `teacherOnlyNote` / `internalMemo`.
 *   - records/bookLogs: data.userId MUST equal the signed-in uid AND the
 *     path owner; fields are whitelisted.
 *   - users/{u}/deliveredProblems: only the ASSIGNED teacher (teaches(u))
 *     or admin may write, data.userId must equal {u}, and answer-bearing
 *     fields are forbidden on student-visible docs.
 *   - teacherProblemAnswers: READ POLICY = A — a teacher may read ONLY the
 *     answers they own (resource.data.teacherId == them) or an admin; a
 *     student's OTHER teachers may NOT read them, even for an assigned
 *     student. Students can NEVER read answers.
 *   - top-level deliveredProblems: read limited to teacher/admin; delete is
 *     owner-limited; admin is NOT exempt from the answer-field ban.
 *
 * Data layout (see src/services/repository/paths.js):
 *   profiles/{uid}                         role/isTeacher/teacherId admin-only
 *   users/{uid}/records/{id}               own study records
 *   users/{uid}/bookLogs/{id}              own reading logs
 *   users/{uid}/deliveredProblems/{id}     delivered problems (NO answers)
 *   public/data/teacherProblems/{id}       global broadcast (NO answers)
 *   deliveredProblems/{id}                  teacher/admin only (NO answers)
 *   teacherProblemAnswers/{id}             answers — owning teacher/admin ONLY
 *                                          (REQUIRES teacherId; studentUid optional)
 *   teacherAllowlist/{uid}                  admin-only; not listable
 *
 * NOTE: teaches() uses get() (1 document read) to check assignment.
 * It only runs on teacher/admin access to a student's data, which is
 * infrequent, so the extra read is acceptable.
 * ============================================================ */
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isSelf(u) { return signedIn() && request.auth.uid == u; }
    function isTeacher() {
      return signedIn() && (request.auth.token.teacher == true || request.auth.token.admin == true);
    }
    function isAdmin() { return signedIn() && request.auth.token.admin == true; }

    function teaches(studentUid) {
      return isTeacher()
        && get(/databases/$(database)/documents/profiles/$(studentUid)).data.teacherId == request.auth.uid;
    }

    // student-visible docs may never carry answer/solution fields
    function noAnswerFields() {
      return !request.resource.data.keys()
        .hasAny(['answer', 'correctAnswer', 'explanation', 'solution', 'answerKey', 'answers']);
    }
    // the row's userId must equal the signed-in user
    function ownsRow() {
      return request.resource.data.userId == request.auth.uid;
    }

    // DM participant check: pairId is the two uids sorted and joined by "__"
    // (see pairId() in src/firebase/firestorePaths.js).
    function dmParticipant(pairId) {
      return signedIn() && (request.auth.uid in pairId.split('__'));
    }

    // student-visible / public docs may never carry authority markers
    function noAuthorityFields() {
      return !request.resource.data.keys()
        .hasAny(['role', 'isTeacher', 'admin', 'teacher', 'teacherId', 'claims', 'permissions']);
    }
    // an update must not change any authority marker
    function authorityUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'isTeacher', 'admin', 'teacher', 'teacherId', 'claims', 'permissions']);
    }
    // a student progress update may touch ONLY these fields — never teacher
    // content (title/body/tasks/subject/dueDate), ownership (teacherUid/studentUid),
    // createdAt, authority, or answer fields. Used for weeklyPlans / sentPlans.
    // NOTE: rules cannot deep-validate array elements, so `items` is allowed as a
    // whole (the student legitimately rewrites items[].progressPercent).
    function studentProgressOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['items', 'overallProgress', 'bookProgress', 'updatedAt']);
    }

    // ---------------- profiles ----------------
    match /profiles/{u} {
      allow get: if isSelf(u) || isAdmin()
                 || (isTeacher() && resource.data.teacherId == request.auth.uid);
      // teacher may list ONLY their own students, and only bounded queries
      allow list: if isAdmin()
                  || (isTeacher()
                      && request.query.limit <= 100
                      && resource.data.teacherId == request.auth.uid);
      // self create/update are WHITELISTED — role/isTeacher/teacherId/admin and
      // any unknown field (teacherOnlyNote, internalMemo, …) are rejected.
      allow create: if isSelf(u)
                    && request.resource.data.keys()
                       .hasOnly(['name', 'bio', 'avatar', 'avatarUrl', 'theme', 'createdAt', 'updatedAt']);
      allow update: if isAdmin()
                    || (isSelf(u)
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['name', 'bio', 'avatar', 'avatarUrl', 'theme', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // ---------------- own study records ----------------
    match /users/{u}/records/{id} {
      allow read:   if isSelf(u) || isAdmin() || teaches(u);
      allow create: if isSelf(u) && ownsRow()
                    && request.resource.data.keys()
                       .hasOnly(['userId', 'minutes', 'subject', 'source', 'createdAt', 'updatedAt']);
      allow update: if isSelf(u) && ownsRow()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['minutes', 'subject', 'source', 'updatedAt']);
      allow delete: if isSelf(u) || isAdmin();
    }

    // ---------------- own reading logs ----------------
    match /users/{u}/bookLogs/{id} {
      allow read:   if isSelf(u) || isAdmin() || teaches(u);
      allow create: if isSelf(u) && ownsRow()
                    && request.resource.data.keys()
                       .hasOnly(['userId', 'title', 'minutes', 'bookId', 'createdAt', 'updatedAt']);
      allow update: if isSelf(u) && ownsRow()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['title', 'minutes', 'bookId', 'updatedAt']);
      allow delete: if isSelf(u) || isAdmin();
    }

    // ---------------- delivered problems (NO answers) ----------------
    // Student reads own inbox; only the ASSIGNED teacher (or admin) writes,
    // the row must be addressed to {u}, and answer fields are forbidden.
    // teacherId policy = B: this per-student doc does NOT carry teacherId (it
    // is not in the whitelist, so it cannot be set/spoofed). The writer is
    // already pinned to the assigned teacher via teaches(u), and userId == u.
    match /users/{u}/deliveredProblems/{id} {
      allow read:   if isSelf(u) || isAdmin() || teaches(u);
      allow create, update: if (isAdmin() || teaches(u))
                            && request.resource.data.userId == u
                            && noAnswerFields()
                            && request.resource.data.keys()
                               .hasOnly(['userId', 'title', 'body', 'subject', 'problemId', 'createdAt', 'updatedAt']);
      allow delete: if isAdmin() || teaches(u);
    }

    // ---------------- global broadcast (NO answers) ----------------
    // admin exception ONLY relaxes the teacherId==self check; answer-field ban
    // and the field whitelist always apply (even for admin). Delete is owner-only.
    match /public/data/teacherProblems/{id} {
      allow read:  if signedIn();
      allow create, update: if (isAdmin() || (isTeacher() && request.resource.data.teacherId == request.auth.uid))
                            && noAnswerFields()
                            && request.resource.data.keys()
                               .hasOnly(['title', 'body', 'subject', 'teacherId', 'createdAt', 'updatedAt']);
      allow delete: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    // ---------------- top-level public problem parts ----------------
    // Students read their copies via users/{uid}/deliveredProblems, so this
    // collection is teacher/admin only and still answer-free. A non-admin
    // teacher must stamp their OWN uid as teacherId (no spoofing); admin may
    // use any teacherId but still cannot include answers. Delete is owner-only.
    match /deliveredProblems/{id} {
      allow read:  if isTeacher();
      allow create, update: if (isAdmin() || (isTeacher() && request.resource.data.teacherId == request.auth.uid))
                            && noAnswerFields()
                            && request.resource.data.keys()
                               .hasOnly(['title', 'body', 'subject', 'teacherId', 'createdAt', 'updatedAt']);
      allow delete: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    // ---------------- ANSWERS: owning teacher / admin ONLY ----------------
    // Students can NEVER read. READ POLICY = A (most strict): only the OWNING
    // teacher (teacherId == them) or an admin may read — NOT a student's other
    // teachers, even for an assigned student. Writes still bind teacherId to
    // the writer and (if studentUid present) require an assigned student.
    match /teacherProblemAnswers/{id} {
      allow read:   if isAdmin()
                    || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow create: if isAdmin()
                    || (isTeacher()
                        && request.resource.data.teacherId == request.auth.uid
                        && (!('studentUid' in request.resource.data) || teaches(request.resource.data.studentUid))
                        && request.resource.data.keys()
                           .hasOnly(['teacherId', 'studentUid', 'problemId', 'answer', 'score', 'feedback', 'createdAt', 'updatedAt']));
      allow update: if isAdmin()
                    || (isTeacher()
                        && resource.data.teacherId == request.auth.uid
                        && request.resource.data.teacherId == request.auth.uid
                        && (!('studentUid' in request.resource.data) || teaches(request.resource.data.studentUid))
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['answer', 'score', 'feedback', 'problemId', 'studentUid', 'updatedAt']));
      allow delete: if isAdmin()
                    || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    // ---------------- teacher allowlist: admin-only, not listable ----------------
    match /teacherAllowlist/{u} {
      allow get:   if isAdmin() || isSelf(u); // a user may check own status only
      allow list:  if false;                  // never enumerate the allowlist
      allow write: if isAdmin();               // only admins grant/revoke teacher rights
    }

    // ============================================================
    // LEGACY MODEL (live app paths). These were exposed by a deployed
    // `allow read, write: if true` wildcard (see FIRESTORE_RULES_DRIFT_AUDIT.md).
    // Locked down to least-privilege. Shapes inferred from
    // src/firebase/firestorePaths.js + feature code; verify with
    // `npm run test:rules` (emulator) before deploying. Paths marked
    // REQUIRES CONFIRMATION are intentionally conservative.
    // ============================================================

    // ---- self profile doc (legacy). Authority markers can never be granted
    // from the client; teacher/admin come from custom claims only. ----
    match /users/{u}/profile/main {
      allow read: if isSelf(u) || isAdmin() || teaches(u);
      allow create: if isSelf(u)
                    && (!('isTeacher' in request.resource.data) || request.resource.data.isTeacher == false)
                    && !request.resource.data.keys()
                         .hasAny(['role', 'admin', 'teacher', 'teacherId', 'claims', 'permissions']);
      allow update: if isAdmin() || (isSelf(u) && authorityUnchanged());
      allow delete: if isAdmin();
    }

    // ---- own friends list (legacy) ----
    match /users/{u}/friends/{friendId} {
      allow read, write: if isSelf(u) || isAdmin();
    }

    // ---- own review "seen" markers (legacy) ----
    match /users/{u}/customSeen/{id} {
      allow read, write: if isSelf(u) || isAdmin();
    }

    // ---- own study diary (legacy) ----
    match /users/{u}/studyDiary/{id} {
      allow read:  if isSelf(u) || isAdmin() || teaches(u);
      allow write: if isSelf(u) || isAdmin();
    }

    // ---- weekly plans the student receives (legacy). Read: student / assigned
    // teacher / admin. Write: student (own progress) OR the teacher named on the
    // plan (teacherUid == self) OR admin. No cross-student access. ----
    match /users/{u}/weeklyPlans/{planId} {
      allow read: if isSelf(u) || isAdmin() || teaches(u);
      // Create: admin, or the teacher named on the plan (no spoofing), addressed
      // to the path owner, answer-free. Students may NOT create plans.
      allow create: if isAdmin()
                    || (isTeacher()
                        && request.resource.data.teacherUid == request.auth.uid
                        && request.resource.data.studentUid == u
                        && noAnswerFields());
      // Update: admin; the owning teacher (teacherUid stays self, answer-free);
      // OR the student — but ONLY progress/status fields on their own plan.
      allow update: if isAdmin()
                    || (isTeacher()
                        && resource.data.teacherUid == request.auth.uid
                        && request.resource.data.teacherUid == request.auth.uid
                        && noAnswerFields())
                    || (isSelf(u) && studentProgressOnly());
      allow delete: if isSelf(u) || isAdmin()
                    || (isTeacher() && resource.data.teacherUid == request.auth.uid);
    }

    // ---- teacher's "sent plans" history (legacy). Read: owning teacher/admin.
    // Create: teacher/admin only. Update: owning teacher/admin, OR the student
    // named on the existing plan mirroring progress (studentUid stays self).
    // REQUIRES CONFIRMATION: student updates are not yet field-whitelisted. ----
    match /users/{u}/sentPlans/{planId} {
      allow read: if isSelf(u) || isAdmin();
      // Create: owning teacher (path owner) or admin only, answer-free. Students
      // may NOT create sent-plan records.
      allow create: if (isSelf(u) || isAdmin()) && noAnswerFields();
      // Update: owning teacher/admin (answer-free); OR the student named on the
      // EXISTING plan mirroring progress — progress/status fields only, and only
      // when the doc already belongs to that student (studentUid == self).
      allow update: if ((isSelf(u) || isAdmin()) && noAnswerFields())
                    || (resource.data.studentUid == request.auth.uid && studentProgressOnly());
      allow delete: if isSelf(u) || isAdmin();
    }

    // ---- direct messages (legacy). Restricted to the two participants encoded
    // in pairId. Messages are create-only (immutable); senderId must be the
    // writer. ----
    match /chats/{pairId} {
      allow read, write: if dmParticipant(pairId);
    }
    match /chats/{pairId}/messages/{messageId} {
      allow read:   if dmParticipant(pairId);
      allow create: if dmParticipant(pairId)
                    && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---- public per-user cards: ranking / user search (legacy). Readable by any
    // signed-in user; writable only by the owner; never authority/answer fields. ----
    match /public/data/customApp/{cardUid} {
      allow read: if signedIn();
      allow create, update: if isSelf(cardUid) && noAuthorityFields() && noAnswerFields();
      allow delete: if isSelf(cardUid) || isAdmin();
    }

    // ---- shared vocabulary catalog (legacy). Students read-only; teacher/admin
    // manage. No answer fields. ----
    match /public/data/customVocabulary/{wordId} {
      allow read: if signedIn();
      allow create, update, delete: if (isTeacher() || isAdmin()) && noAnswerFields();
    }

    // ---- shared book catalog (legacy). Any signed-in user adds their OWN book
    // (booksApi.addBook stamps ownerUid); only the owner or admin may modify or
    // remove. Shared read. No answer fields. ----
    match /public/data/bookShelf/{bookId} {
      allow read: if signedIn();
      allow create: if signedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && noAnswerFields();
      allow update: if isAdmin()
                    || (signedIn() && resource.data.ownerUid == request.auth.uid && noAnswerFields());
      allow delete: if isAdmin() || (signedIn() && resource.data.ownerUid == request.auth.uid);
    }

    // ---- public book logs (legacy). Owner field is `uid` (booksApi.addBookLog).
    // Shared read; each user writes only their own logs. ----
    match /public/data/bookLogs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin()
                    || (signedIn()
                        && resource.data.uid == request.auth.uid
                        && request.resource.data.uid == request.auth.uid);
      allow delete: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // NOTE: other legacy public/data docs referenced by firestorePaths.js
    // (teacherIndex, sharedApps) use odd-segment doc() paths flagged TODO/best-
    // guess in that file; they are intentionally left under the default-deny
    // below until their real shape/usage is confirmed (REQUIRES CONFIRMATION).

    // ============================================================
    // LEGACY LIVE APP (artifacts/{appId}/...)
    // The deployed legacy bundle stores ALL data under artifacts/{appId}/... ,
    // NOT the top-level paths above. The hardening deploy left this subtree under
    // default-deny, which broke login/signup: a per-user `friends` onSnapshot and
    // the user's own profile reads/writes were permission-denied. Restore the live
    // app at least-privilege:
    //   - each user controls ONLY their own subtree (no cross-user access);
    //   - shared public/data is signed-in READ only (study content — the legacy
    //     app has NO separate teacher answer-key collection);
    //   - the user's own leaderboard/search card is self-write (streak/exp on login);
    //   - all OTHER shared writes stay denied (teacher/shared writes are a
    //     documented follow-up).
    // No allow-true, no cross-user access, no broad authenticated write.
    // ============================================================
    match /artifacts/{appId} {
      // per-user private data: owner only (profile/main, friends, studyDiary,
      // history, review, userVocab, ...). Fixes the failing friends onSnapshot.
      match /users/{uid}/{document=**} {
        allow read, write: if isSelf(uid);
      }
      // shared catalogs / leaderboard: any signed-in user may READ; writes are
      // denied by default (see the own-card exception below).
      match /public/data/{document=**} {
        allow read: if signedIn();
        allow write: if false;
      }
      // teacher announcements (legacy live path: the bundle writes
      // artifacts/{appId}/public/data/announcements/{id} = {text, timestamp, uid}).
      // Signed-in READ; only a teacher/admin (server-set custom claim) may write.
      // A more-specific match than the public/data wildcard above — Firestore ORs
      // the allow rules, so this grants teacher writes while the wildcard keeps
      // every OTHER public/data path write-denied. Restores the broken お知らせ send.
      match /public/data/announcements/{id} {
        allow read: if signedIn();
        allow create, update, delete: if isTeacher();
      }
      // global app lock / emergency stop (legacy live path: the bundle writes
      // artifacts/{appId}/public/data/system/appLock = {locked, message, updatedAt}).
      // Signed-in clients read it via the public/data wildcard above (no extra read
      // rule here, so unauthenticated read stays limited to the login directories);
      // only a teacher/admin may SET it. Firestore ORs the allow rules, so this
      // grants the teacher write while other public/data writes stay denied.
      match /public/data/system/{docId} {
        allow write: if isTeacher();
      }
      // The user's own public card (leaderboard / search). It is ALSO the PRIMARY
      // Friend ID login directory: login queries `where("shortId","==", id)` on
      // customApp FIRST (teacherIndex is only a fallback), BEFORE the user is
      // authenticated — so READ must be PUBLIC (unauthenticated), like
      // teacherIndex. Exposes only public card fields (uid, name, avatar, color,
      // xp, streak, shortId); no authority, no answers. WRITE stays owner-only.
      match /public/data/customApp/{cardUid} {
        allow read: if true;
        allow write: if isSelf(cardUid);
      }
      // Friend ID login directory. Despite the legacy name, EVERY user has their
      // OWN entry here (doc id = the user's uid; fields {shortId, uid, name,
      // avatar, color}). Friend ID login resolves a Friend ID -> uid by querying
      // `where("shortId","==", id)` BEFORE the user is authenticated, so READ
      // must be PUBLIC (unauthenticated). This is a scoped, intentional public
      // login directory — NOT the rest of public/data, which stays signed-in
      // read. It exposes only public lookup fields; no authority, no answers.
      // WRITE stays owner-only (doc id == uid) and authority/answer free.
      match /public/data/teacherIndex/{docId} {
        allow read: if true;
        allow write: if isSelf(docId) && noAuthorityFields() && noAnswerFields();
      }
      // Teacher WEEKLY PLANS (live legacy path: public/data/weeklyTasks). The bundle
      // CREATEs/DELETEs plan docs here {subject,total,unit,assignedTo,createdBy,
      // createdAt,deadline,rangeStart,rangeEnd} — no authority/answer fields. The
      // hardening's blanket public/data write-deny had broken plan sending; restore
      // it as TEACHER/ADMIN-write only (server-set claim). Signed-in READ via the
      // public/data wildcard above. (Firestore ORs allow rules across matching blocks.)
      match /public/data/weeklyTasks/{taskId} {
        allow create, update: if isTeacher() && noAuthorityFields() && noAnswerFields();
        allow delete: if isTeacher();
      }
      // Study / book-time LOGS (live legacy path: public/data/bookLogs). Each doc
      // carries uid = its owner; the owner creates their own log, and the owner or a
      // teacher may update (teacher comment / like) / delete. Read stays signed-in
      // (wildcard). NOTE: the doc includes a denormalized `isTeacher` DISPLAY flag —
      // it is NOT an auth source (roles come only from custom claims), so we do not
      // apply noAuthorityFields() here. Restores study/time recording that the
      // public/data write-deny had broken.
      match /public/data/bookLogs/{logId} {
        allow create: if signedIn()
                      && request.resource.data.uid == request.auth.uid
                      && noAnswerFields();
        allow update, delete: if signedIn()
                              && (resource.data.uid == request.auth.uid || isTeacher());
      }
      // Teacher problem distribution (live legacy paths). The bundle CREATEs/DELETEs
      // word problems at public/data/customVocabulary and distributed apps/links at
      // public/data/sharedApps; the blanket public/data write-deny had broken both
      // (先生: 問題配布・削除ができない). TEACHER/ADMIN write only (server-set claim);
      // authority/answer-field free. Signed-in READ stays via the public/data
      // wildcard. NOTE: this does NOT re-enable the student `seenBy` write (students
      // are not teachers) — per-student progress stays in users/{uid}/customSeen.
      match /public/data/customVocabulary/{vId} {
        allow create, update: if isTeacher() && noAuthorityFields() && noAnswerFields();
        allow delete: if isTeacher();
      }
      match /public/data/sharedApps/{appId} {
        allow create, update: if isTeacher() && noAuthorityFields() && noAnswerFields();
        allow delete: if isTeacher();
      }

      // ---- direct messages (legacy live path). The legacy app stores DMs at
      // artifacts/{appId}/chats/{pairId}, where pairId is the two uids sorted and
      // joined by "_" (see [a,b].sort().join("_")). Restricted to the two
      // participants (Firebase uids are alphanumeric, so split('_') yields the two
      // uids). Each message records its sender as `uid`; messages are create-only
      // (immutable). No cross-user access. ----
      match /chats/{pairId} {
        allow read, write: if signedIn() && (request.auth.uid in pairId.split('_'));
        match /messages/{messageId} {
          allow read: if signedIn() && (request.auth.uid in pairId.split('_'));
          allow create: if signedIn()
                        && (request.auth.uid in pairId.split('_'))
                        && request.resource.data.uid == request.auth.uid;
          allow update, delete: if false;
        }
      }
    }

    // ---------------- default deny ----------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
