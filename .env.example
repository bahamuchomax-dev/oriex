VITE_FIREBASE_AUTH_DOMAIN=genro-b74de.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=genro-b74de
VITE_FIREBASE_STORAGE_BUCKET=genro-b74de.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=311645846310
VITE_FIREBASE_APP_ID=1:311645846310:web:4a11cadf49825db1f55fe7
