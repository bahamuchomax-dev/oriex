rules_version = '2';
// ============================================================================
// 注意：
// このルールはPhase 2移行後の理想形です。
// 現行コードはまだ profile.password を使用しているため、このまま本番適用すると
// 登録・ログインが壊れる可能性があります。
// 本番適用前に Firebase Auth 方式へ移行してください。
//
// ルールは用途別に2分割しました：
//   - firestore.rules.phase1.example : 現行ログイン（匿名認証＋password比較）を
//                                       壊さない暫定ルール（まず適用するならこちら）
//   - firestore.rules.phase2.example : Firebase Auth 移行後の安全な理想ルール
// 適用タイミングは SECURITY_NOTES.md を参照してください。
// 以下は従来の理想形ルール（= Phase 2 とほぼ同等）を参考として残しています。
// ============================================================================
// Oriex Firestore Rules — DRAFT / 要検証
// 実データ構造に合わせて調整し、エミュレータ等で十分にテストしてから適用すること。
// データパス規約: artifacts/gen-ron-kai-app-v1/users/{uid}/... と
//                 artifacts/gen-ron-kai-app-v1/public/data/...
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function uid()        { return request.auth.uid; }
    // Phase 2（Custom Claims 導入後）に有効化:
    function role()       { return request.auth.token.role; }       // 'student'|'teacher'|'admin'
    function isTeacher()  { return role() == 'teacher' || role() == 'admin'; }
    function isAdmin()    { return role() == 'admin'; }

    match /artifacts/gen-ron-kai-app-v1 {

      // ===== 本人プロフィール =====
      // 暫定（Custom Claims 未導入）でも最低限これだけは守る:
      //  - 未ログイン拒否
      //  - 本人のみ write
      //  - 自己昇格（isTeacher:true への変更）を禁止
      //  - 平文 password を保存させない
      match /users/{userId}/{document=**} {
        allow read:  if isSignedIn() && (uid() == userId /* || isTeacher() */);
        allow write: if isSignedIn() && uid() == userId
                     && !(
                          'isTeacher' in request.resource.data
                          && request.resource.data.isTeacher == true
                          && (resource == null || resource.data.isTeacher != true)
                        )
                     && !('password' in request.resource.data);
      }

      // ===== 公開リーダーボード（XP/score）=====
      match /public/data/customApp/{userId} {
        allow read:  if isSignedIn();
        allow write: if isSignedIn() && uid() == userId
                     && request.resource.data.totalExp is int
                     && request.resource.data.totalExp >= 0
                     && request.resource.data.totalExp <= 10000000
                     && (resource == null
                         || request.resource.data.totalExp
                            <= resource.data.totalExp + 5000); // 1回の増分上限（要調整）
      }

      // ===== 提出状況 =====
      match /public/data/taskProgress/{progressId} {
        allow read:  if isSignedIn() && (/* isTeacher() || */ resource.data.uid == uid());
        allow create, update: if isSignedIn()
                     && request.resource.data.uid == uid()      // uid 偽装防止
                     && request.resource.data.done is int
                     && request.resource.data.done >= 0;
      }

      // ===== 先生配信問題・お知らせ・設定（Phase 2: 教師/管理者のみ書込）=====
      match /public/data/customVocabulary/{id} {
        allow read:  if isSignedIn();
        allow write: if isSignedIn() /* && isTeacher() */;
      }
      match /public/data/announcements/{id} {
        allow read:  if isSignedIn();
        allow write: if isSignedIn() /* && isTeacher() */;
      }
      match /public/data/settings/{id} {       // inviteCode 等
        allow read:  if isSignedIn();
        allow write: if isSignedIn() /* && isAdmin() */;
      }
      match /public/data/teacherIndex/{userId} {
        allow read:  if isSignedIn();
        allow write: if isSignedIn() /* && isTeacher() */;
      }

      // ===== チャット =====
      match /public/data/chat/{msgId} {
        allow read:  if isSignedIn();
        allow create: if isSignedIn()
                     && request.resource.data.uid == uid()
                     && request.resource.data.text is string
                     && request.resource.data.text.size() <= 1000;
        allow update, delete: if isSignedIn() /* && isTeacher() */;
      }

      // 明示しないものはすべて拒否（デフォルト deny）
    }
  }
}

// ---- Storage（未使用なら全 deny） ----
