rules_version = '2';
// ============================================================================
// Oriex Firestore Rules — PHASE 2（理想 / Firebase Auth 移行後）
// ----------------------------------------------------------------------------
// 注意：
// このルールは Phase 2 移行後の理想形です。
// 現行コードはまだ profile.password を使用しているため、このまま本番適用すると
// 登録・ログインが壊れる可能性があります。
// 本番適用前に Firebase Auth（Email/Password）方式へ移行してください。
//
// 前提：
// ・ログインは signInWithEmailAndPassword / 登録は createUserWithEmailAndPassword
// ・教師/管理者は Custom Claims（request.auth.token.role）で付与（Admin SDK 経由）
// ・profile に平文 password を保存しない
// 実データ構造に合わせて調整し、エミュレータで十分にテストすること（要検証）。
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function uid()        { return request.auth.uid; }
    function role()       { return request.auth.token.role; }        // 'student'|'teacher'|'admin'
    function isTeacher()  { return role() == 'teacher' || role() == 'admin'; }
    function isAdmin()    { return role() == 'admin'; }

    match /artifacts/gen-ron-kai-app-v1 {

      // ===== 本人プロフィール =====
      // password 平文保存を禁止。自己昇格も禁止。教師は read のみ可。
      match /users/{userId}/{document=**} {
        allow read:  if isSignedIn() && (uid() == userId || isTeacher());
        allow write: if isSignedIn() && uid() == userId
                     && !('password' in request.resource.data)
                     && !(
                          'isTeacher' in request.resource.data
                          && request.resource.data.isTeacher == true
                          && (resource == null || resource.data.isTeacher != true)
                        );
      }

      // ===== 公開リーダーボード（XP/score）=====
      match /public/data/customApp/{userId} {
        allow read:  if isSignedIn();
        allow write: if isSignedIn() && uid() == userId
                     && request.resource.data.totalExp is int
                     && request.resource.data.totalExp >= 0
                     && request.resource.data.totalExp <= 10000000
                     && (resource == null
                         || request.resource.data.totalExp
                            <= resource.data.totalExp + 5000); // 増分上限（要調整）
      }

      // ===== 提出状況 =====
      match /public/data/taskProgress/{progressId} {
        allow read:  if isSignedIn() && (isTeacher() || resource.data.uid == uid());
        allow create, update: if isSignedIn()
                     && request.resource.data.uid == uid()
                     && request.resource.data.done is int
                     && request.resource.data.done >= 0;
      }

      // ===== 先生配信・お知らせ・設定・index・チャット =====
      match /public/data/customVocabulary/{id} {
        allow read:  if isSignedIn();
        allow write: if isTeacher();
      }
      match /public/data/announcements/{id} {
        allow read:  if isSignedIn();
        allow write: if isTeacher();
      }
      match /public/data/settings/{id} {
        allow read:  if isSignedIn();
        allow write: if isAdmin();
      }
      match /public/data/teacherIndex/{userId} {
        allow read:  if isSignedIn();
        allow write: if isTeacher();
      }
      match /public/data/chat/{msgId} {
        allow read:  if isSignedIn();
        allow create: if isSignedIn()
                     && request.resource.data.uid == uid()
                     && request.resource.data.text is string
                     && request.resource.data.text.size() <= 1000;
        allow update, delete: if isTeacher();
      }

      // 明示しないものは拒否（デフォルト deny）
    }
  }
}

// ---- Storage（未使用なら全 deny） ----
