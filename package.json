    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.2",
    "firebase": "^12.14.0",
    "firebase-tools": "^15.20.0",
    "globals": "15.11.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "uuid": "^11.1.1"
